# .env.example — Copy to .env and fill in values
# All values can also be set in config.json

# ── API Keys ──────────────────────────────────────────────────────────────────
# NewsAPI.org — Free tier: 100 req/day
# Register at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# NIST NVD — Optional API key for higher rate limits (50 req/30s vs 5 req/30s)
# Register at: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# HuggingFace — Free tier inference (text + image generation)
# Create token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=hf_your_token_here

# Anthropic Claude — For AI-powered caption generation
# Claude Haiku is cheapest. Also set in config.json: claude_model
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Backend switches ──────────────────────────────────────────────────────────
CAPTION_BACKEND=template      # template | ai
IMAGE_BACKEND=placeholder     # placeholder | remote
